# Runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Optional: path to ETL-produced JSON/CSV file consumed by /api/v1/timeseries
TIMESERIES_DATA_PATH=fixtures/timeseries.sample.json

# In-memory timeseries LRU cache tuning
TIMESERIES_CACHE_MAX_ENTRIES=200
TIMESERIES_CACHE_TTL_MS=60000

# Python ETL layer (kept for compatibility with existing data pipeline)
DATABASE_URL=sqlite:///db/country_stats.db
WORLDBANK_API_BASE=https://api.worldbank.org/v2
WORLDBANK_DATA360_BASE=https://data360.worldbank.org/api
OECD_API_BASE=https://sdmx.oecd.org/public/rest
OECD_API_V2_BASE=https://sdmx.oecd.org/public/rest/v2
API_TIMEOUT=30
API_RETRY_MAX=3
API_BACKOFF_FACTOR=2
DATA_START_YEAR=2015
DATA_END_YEAR=2024
